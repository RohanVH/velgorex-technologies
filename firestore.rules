rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'password');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUser(data) {
      let requiredFields = data.keys().hasAll(['email', 'username', 'contactNumber', 'createdAt']);
      let allowedFields = data.keys().hasOnly(['email', 'username', 'contactNumber', 'createdAt', 'lastLoginAt', 'displayName', 'updatedAt', 'photoURL']);
      
      return requiredFields && allowedFields &&
             data.email is string && data.email.size() <= 256 &&
             data.username is string && data.username.size() >= 1 && data.username.size() <= 50 &&
             data.contactNumber is string && data.contactNumber.size() <= 30 &&
             data.createdAt is timestamp &&
             (data.get('lastLoginAt', request.time) is timestamp) &&
             (data.get('updatedAt', request.time) is timestamp) &&
             (data.get('displayName', '') is string) &&
             (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 1000000);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      isVerified() &&
                      isValidId(userId) && 
                      isValidUser(incoming()) &&
                      incoming().createdAt <= request.time;
      allow update: if isOwner(userId) && 
                      isVerified() &&
                      isValidUser(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().email == existing().email &&
                      (incoming().username == existing().username || !('username' in existing())) &&
                      (
                        incoming().diff(existing()).affectedKeys().hasOnly(['lastLoginAt', 'displayName', 'contactNumber', 'updatedAt', 'username', 'photoURL'])
                      );
    }
  }
}
