{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile and account information",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's primary email address"
        },
        "username": {
          "type": "string",
          "description": "Unique username"
        },
        "contactNumber": {
          "type": "string",
          "description": "Contact phone number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user account was created"
        },
        "lastLoginAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last time the user logged in"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user profile was last updated"
        },
        "displayName": {
          "type": "string",
          "description": "Full name or display name"
        },
        "photoURL": {
          "type": "string",
          "description": "Base64 encoded profile picture data"
        }
      },
      "required": ["email", "username", "contactNumber", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user document indexed by Firebase Auth UID"
    }
  }
}
